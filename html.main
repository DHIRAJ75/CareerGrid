            <div class="stat-label">AI Queries Used</div>
            <div class="stat-value teal" id="stat-queries">0 / 5</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Skill Gap Score</div>
            <div class="stat-value" id="stat-gap">—</div>
          </div>
        </div>
        <div id="roadmap-list-container">
          <div style="color:var(--text2);font-size:0.9rem;background:var(--card);border:1px solid var(--border);border-radius:16px;padding:2.5rem;text-align:center" id="empty-state">
