<script>
// ═══════════════════════════════════════════════════════
//  CONFIG — REPLACE WITH YOUR NEW KEYS AFTER ROTATING
// ═══════════════════════════════════════════════════════
const CONFIG = {
  GOOGLE_CLIENT_ID: 'YOUR_NEW_GOOGLE_CLIENT_ID.apps.googleusercontent.com',
  CEREBRAS_API_KEY: 'YOUR_NEW_CEREBRAS_API_KEY',
  CEREBRAS_API_URL: 'https://api.cerebras.ai/v1/chat/completions',
  CEREBRAS_MODEL:   'llama-3.1-70b',
};

// ═══════════════════════════════════════════════════════
//  APP STATE
// ═══════════════════════════════════════════════════════
const STATE = {
  user:      null,   // { id, name, email, initials, provider }
  plan:      'free', // free | starter | pro | elite
  profile:   null,   // onboarding answers
  roadmaps:  [],     // generated roadmaps
  queries:   0,      // used this month
  queryLimits: { free:5, starter:50, pro:-1, elite:-1 },
  annualBilling: false,
  currentRoadmap: null,
};

// ─── Local persistence ───
function saveState() {
  const s = { user: STATE.user, plan: STATE.plan, profile: STATE.profile,
              roadmaps: STATE.roadmaps, queries: STATE.queries };
  localStorage.setItem('cg_state', JSON.stringify(s));
}
function loadState() {
  try {
    const s = JSON.parse(localStorage.getItem('cg_state') || 'null');
    if (s) { Object.assign(STATE, s); return true; }
  } catch(e) {}
  return false;
}

// ═══════════════════════════════════════════════════════
//  GOOGLE SIGN-IN SETUP
// ═══════════════════════════════════════════════════════
function initGoogleSignIn() {
  if (!window.google) { setTimeout(initGoogleSignIn, 300); return; }
  google.accounts.id.initialize({
    client_id: CONFIG.GOOGLE_CLIENT_ID,
    callback: handleGoogleCredential,
    auto_select: false,
    cancel_on_tap_outside: true,
  });
  google.accounts.id.renderButton(
    document.getElementById('google-signin-btn'),
    { theme: 'filled_black', size: 'large', width: 320, text: 'signin_with', shape: 'rectangular' }
  );
}

function handleGoogleCredential(response) {
  try {
    // Decode JWT payload (base64 middle part)
    const payload = JSON.parse(atob(response.credential.split('.')[1]));
    const user = {
      id:       payload.sub,
      name:     payload.name || payload.email.split('@')[0],
      email:    payload.email,
      picture:  payload.picture || null,
      initials: (payload.name || payload.email).split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase(),
      provider: 'google',
    };
    loginSuccess(user);
  } catch(e) {
    showAuthError('Google sign-in failed. Please try again.');
  }
}

// ═══════════════════════════════════════════════════════
//  EMAIL AUTH (simulated — replace with Supabase in prod)
// ═══════════════════════════════════════════════════════
function handleEmailLogin() {
  const email    = document.getElementById('login-email').value.trim();
  const password = document.getElementById('login-password').value;
  if (!email || !password) { showAuthError('Please enter email and password.'); return; }
  if (!email.includes('@')) { showAuthError('Invalid email address.'); return; }
  if (password.length < 6) { showAuthError('Password too short.'); return; }

  // Check local "accounts" store
  const accounts = JSON.parse(localStorage.getItem('cg_accounts') || '{}');
  if (!accounts[email]) { showAuthError('Account not found. Please sign up first.'); return; }
  if (accounts[email].password !== btoa(password)) { showAuthError('Incorrect password.'); return; }

  loginSuccess(accounts[email].user);
}

function handleEmailSignup() {
  const name     = document.getElementById('signup-name').value.trim();
  const email    = document.getElementById('signup-email').value.trim();
  const password = document.getElementById('signup-password').value;
  if (!name)               { showAuthError('Please enter your name.'); return; }
  if (!email.includes('@')){ showAuthError('Invalid email address.'); return; }
  if (password.length < 8) { showAuthError('Password must be at least 8 characters.'); return; }

  const accounts = JSON.parse(localStorage.getItem('cg_accounts') || '{}');
  if (accounts[email]) { showAuthError('Email already registered. Please sign in.'); return; }

  const user = {
    id:       'local_' + Date.now(),
    name,
    email,
    initials: name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase(),
    provider: 'email',
  };
  accounts[email] = { password: btoa(password), user };
  localStorage.setItem('cg_accounts', JSON.stringify(accounts));
  loginSuccess(user);
}

function loginSuccess(user) {
  STATE.user = user;
  const existing = JSON.parse(localStorage.getItem('cg_state') || 'null');
  if (existing && existing.user && existing.user.id === user.id) {
    loadState();
    STATE.user = user; // refresh user object
  }
  saveState();
  const needsOnboarding = !STATE.profile;
  if (needsOnboarding) {
    showScreen('onboarding');
  } else {
    enterApp();
  }
}

function handleLogout() {
  if (window.google) google.accounts.id.disableAutoSelect();
  saveState();
  STATE.user = null;
  document.getElementById('user-menu').classList.remove('open');
  showScreen('login');
}

function showAuthError(msg) {
  const el = document.getElementById('auth-error');
  el.textContent = msg;
  el.style.display = 'block';
  setTimeout(() => el.style.display = 'none', 4000);
}
function showLogin()  { document.getElementById('form-login').style.display='block'; document.getElementById('form-signup').style.display='none'; document.getElementById('auth-error').style.display='none'; }
function showSignup() { document.getElementById('form-login').style.display='none'; document.getElementById('form-signup').style.display='block'; document.getElementById('auth-error').style.display='none'; }

// ═══════════════════════════════════════════════════════
//  SCREENS
// ═══════════════════════════════════════════════════════
function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + name).classList.add('active');
}

function enterApp() {
  updateTopbar();
  updateDashboard();
  showScreen('app');
  showView('dashboard');
}

// ═══════════════════════════════════════════════════════
//  VIEWS
// ═══════════════════════════════════════════════════════
function showView(name) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.sidebar-item').forEach(i => i.classList.remove('active'));
  document.getElementById('view-' + name).classList.add('active');
  const navEl = document.getElementById('nav-' + name);
  if (navEl) navEl.classList.add('active');
  document.getElementById('user-menu').classList.remove('open');
  if (name === 'dashboard') updateDashboard();
}

// ═══════════════════════════════════════════════════════
//  TOPBAR / PROFILE UPDATES
// ═══════════════════════════════════════════════════════
function updateTopbar() {
  const u = STATE.user;
  if (!u) return;
  document.getElementById('user-initials').textContent = u.initials || 'U';
  document.getElementById('menu-email').textContent    = u.email;
  document.getElementById('profile-avatar-large').textContent = u.initials || 'U';
  document.getElementById('profile-name-text').textContent    = u.name;
  document.getElementById('profile-email-text').textContent   = u.email;
  document.getElementById('dash-name').textContent = u.name.split(' ')[0];

  const planMap = { free:'Free', starter:'Starter', pro:'Pro', elite:'Elite' };
  const badgeEl = document.getElementById('topbar-plan-badge');
  badgeEl.textContent  = planMap[STATE.plan] || 'Free';
  badgeEl.className    = 'plan-badge plan-' + STATE.plan;
  document.getElementById('profile-plan-badge').textContent = (planMap[STATE.plan]||'Free') + ' Plan';
  document.getElementById('profile-plan-badge').className   = 'plan-badge plan-' + STATE.plan;

  const limit   = STATE.queryLimits[STATE.plan];
  const limitTx = limit === -1 ? '∞' : limit;
  document.getElementById('stat-queries').textContent = STATE.queries + ' / ' + limitTx;
  document.getElementById('usage-text').textContent   = STATE.queries + ' / ' + limitTx + ' queries used';
  const pct = limit === -1 ? 10 : Math.min(100, (STATE.queries / limit) * 100);
  document.getElementById('usage-bar').style.width = pct + '%';
}

function updateDashboard() {
  updateTopbar();
  document.getElementById('stat-roadmaps').textContent = STATE.roadmaps.length;
  const hasRoadmaps = STATE.roadmaps.length > 0;
  document.getElementById('empty-state').style.display    = hasRoadmaps ? 'none' : 'block';
  document.getElementById('roadmap-list').style.display   = hasRoadmaps ? 'flex' : 'none';

  if (hasRoadmaps) {
    const last = STATE.roadmaps[STATE.roadmaps.length - 1];
    const score = last.skill_gap_score;
    document.getElementById('stat-gap').textContent = score ? score + '%' : '—';
    renderRoadmapList();
  }
}

function renderRoadmapList() {
  const list = document.getElementById('roadmap-list');
  list.innerHTML = '';
  [...STATE.roadmaps].reverse().forEach((rm, i) => {
    const idx = STATE.roadmaps.length - 1 - i;
    const unlockedPhases = rm.phases ? rm.phases.filter(p => !p.is_locked).length : 0;
    const totalPhases    = rm.phases ? rm.phases.length : 4;
    const card = document.createElement('div');
    card.className = 'roadmap-card';
    card.onclick = () => openRoadmapDetail(idx);
    card.innerHTML = `
      <div class="roadmap-card-header">
        <div>
          <div class="roadmap-card-title">${rm.target_role}</div>
          <div class="roadmap-card-meta">From: ${rm.current_role || 'Your current role'} · ${rm.generated_at ? new Date(rm.generated_at).toLocaleDateString('en-IN') : 'Recently'}</div>
        </div>
        <div class="roadmap-card-badge">${rm.estimated_transition_months || '?'} months</div>
      </div>
      <div class="phase-pills">
        ${Array.from({length:4},(_,j)=>`<div class="phase-pill ${j<unlockedPhases?'unlocked':'locked'}">Phase ${j+1}</div>`).join('')}
      </div>`;
    list.appendChild(card);
  });
}

// ═══════════════════════════════════════════════════════
//  ONBOARDING
// ═══════════════════════════════════════════════════════
let obStep = 0;
let selectedExp = null;
let selectedSkills = [];
let selectedGoals = [];

const stepTitles = [
  "What's your current role?",
  "What skills do you already have?",
  "Where do you want to go?",
  "Almost done — preferences"
];
const stepSubs = [
  "Tell us where you are right now",
  "Select all skills that apply to you",
  "Choose your target career destination",
  "Help us personalise your roadmap"
];

function updateProgressBar() {
  for (let i = 0; i < 4; i++) {
    const seg = document.getElementById('seg' + i);
    seg.className = 'progress-seg' + (i < obStep ? ' done' : i === obStep ? ' active' : '');
  }
  document.getElementById('step-title').textContent = stepTitles[obStep];
  document.getElementById('step-sub').textContent   = stepSubs[obStep];
  document.getElementById('btn-back').style.visibility = obStep === 0 ? 'hidden' : 'visible';
  document.getElementById('btn-next').textContent = obStep === 3 ? 'Generate Roadmap ✦' : 'Next →';
}

function selectExp(btn, val) {
  document.querySelectorAll('.seg-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  selectedExp = val;
}

function toggleSkill(chip) { chip.classList.toggle('selected'); selectedSkills = [...document.querySelectorAll('#skills-chips .chip.selected')].map(c=>c.textContent); }
function toggleGoal(chip)  { chip.classList.toggle('selected'); selectedGoals  = [...document.querySelectorAll('#goal-chips .chip.selected')].map(c=>c.textContent); }

function nextStep() {
  if (obStep === 0) {
    if (!document.getElementById('ob-current-role').value.trim()) { showToast('Please enter your current role','error'); return; }
    if (!selectedExp) { showToast('Please select your experience level','error'); return; }
  }
  if (obStep === 1 && selectedSkills.length === 0) { showToast('Please select at least one skill','error'); return; }
  if (obStep === 2) {
    if (!document.getElementById('ob-target-role').value) { showToast('Please select a target role','error'); return; }
    if (!document.getElementById('ob-industry').value)    { showToast('Please select an industry','error'); return; }
  }
  if (obStep === 3) {
    if (!document.getElementById('ob-city').value) { showToast('Please select a city','error'); return; }
    // Save profile and go to app
    STATE.profile = {
      current_role:     document.getElementById('ob-current-role').value.trim(),
      experience_years: parseInt(selectedExp || '0'),
      experience_label: ['Fresher','1–3 years','3–5 years','5+ years'][parseInt((selectedExp||0)/2)] || 'Fresher',
      skills:           selectedSkills,
      target_role:      document.getElementById('ob-target-role').value,
      industry:         document.getElementById('ob-industry').value,
      city:             document.getElementById('ob-city').value,
      goal_type:        selectedGoals,
    };
    saveState();
    // Pre-fill generate form
    document.getElementById('gen-current-role').value = STATE.profile.current_role;
    document.getElementById('gen-target-role').value  = STATE.profile.target_role;
    document.getElementById('gen-skills').value       = STATE.profile.skills.join(', ');
    enterApp();
    showView('generate');
    return;
  }
  document.getElementById('step-' + obStep).classList.remove('active');
  obStep++;
  document.getElementById('step-' + obStep).classList.add('active');
  updateProgressBar();
}

function prevStep() {
  if (obStep === 0) return;
  document.getElementById('step-' + obStep).classList.remove('active');
  obStep--;
  document.getElementById('step-' + obStep).classList.add('active');
  updateProgressBar();
}

// ═══════════════════════════════════════════════════════
//  CEREBRAS AI — ROADMAP GENERATION
// ═══════════════════════════════════════════════════════
async function generateRoadmap() {
  const currentRole = document.getElementById('gen-current-role').value.trim();
  const targetRole  = document.getElementById('gen-target-role').value;
  const skills      = document.getElementById('gen-skills').value;
  const experience  = document.getElementById('gen-experience').value;
  const city        = document.getElementById('gen-city').value;
  const industry    = document.getElementById('gen-industry').value;
  const goal        = document.getElementById('gen-goal').value;

  if (!currentRole) { showToast('Please enter your current role', 'error'); return; }
  if (!targetRole)  { showToast('Please select your target role', 'error'); return; }

  const limit = STATE.queryLimits[STATE.plan];
  if (limit !== -1 && STATE.queries >= limit) {
    showToast('Query limit reached. Upgrade your plan!', 'error');
    setTimeout(() => showView('paywall'), 1500);
    return;
  }

  // Show generating overlay
  document.getElementById('generate-form').style.display  = 'none';
  document.getElementById('gen-overlay').classList.add('active');
  animateGenSteps();

  const prompt = buildRoadmapPrompt({ currentRole, targetRole, skills, experience, city, industry, goal, tier: STATE.plan });

  try {
    const response = await fetch(CONFIG.CEREBRAS_API_URL, {
      method: 'POST',
      headers: {
        'Content-Type':  'application/json',
        'Authorization': 'Bearer ' + CONFIG.CEREBRAS_API_KEY,
      },
      body: JSON.stringify({
        model:      CONFIG.CEREBRAS_MODEL,
        max_tokens: 4096,
        temperature: 0.7,
        messages: [
          { role: 'system', content: SYSTEM_PROMPT },
          { role: 'user',   content: prompt },
        ],
      }),
    });

    if (!response.ok) {
      const err = await response.json().catch(() => ({}));
      throw new Error(err.error?.message || 'API error ' + response.status);
    }

    const data    = await response.json();
    const rawText = data.choices?.[0]?.message?.content || '';
    const roadmap = parseRoadmapJSON(rawText);

    roadmap.current_role  = currentRole;
    roadmap.generated_at  = new Date().toISOString();
    roadmap.tier_used     = STATE.plan;

    // Apply tier gating
    if (STATE.plan === 'free') {
      roadmap.phases = roadmap.phases.map((p, i) => i === 0
        ? { ...p, is_locked: false }
        : { ...p, is_locked: true, lock_reason: 'Upgrade to Starter ₹99/mo to unlock' }
      );
      roadmap.salary_range_inr = null;
    }

    STATE.roadmaps.push(roadmap);
    STATE.queries++;
    saveState();

    document.getElementById('gen-overlay').classList.remove('active');
    document.getElementById('generate-form').style.display = 'block';

    openRoadmapDetail(STATE.roadmaps.length - 1);
    showView('detail');
    updateTopbar();
    showToast('Roadmap generated successfully!', 'success');

  } catch(err) {
    document.getElementById('gen-overlay').classList.remove('active');
    document.getElementById('generate-form').style.display = 'block';
    showToast('Error: ' + err.message, 'error');
    console.error('Cerebras error:', err);
  }
}

async function generateExclusive(roleHint) {
  document.getElementById('gen-current-role').value = STATE.profile?.current_role || 'Professional';
  document.getElementById('gen-target-role').value  = roleHint.split(' ')[0] + ' ' + (roleHint.split(' ')[1] || '');
  document.getElementById('gen-skills').value       = STATE.profile?.skills?.join(', ') || 'Python, SQL';
  showView('generate');
  showToast('Pre-filled for ' + roleHint.split(' ').slice(0,3).join(' '), 'info');
}

const SYSTEM_PROMPT = `You are CareerGrid AI, an expert Indian career strategist. You have deep knowledge of the Indian job market, Indian companies, Indian salaries, NPTEL/IIT courses, and India-specific career paths.

Return ONLY a valid JSON object — no markdown fences, no explanation, no text before or after the JSON. The JSON must exactly match the schema.

CRITICAL: Your JSON must be complete and valid. Use double quotes for all strings. No trailing commas.`;

function buildRoadmapPrompt({ currentRole, targetRole, skills, experience, city, industry, goal, tier }) {
  return `Generate a detailed career roadmap for this Indian professional:
- Current role: ${currentRole}
- Current skills: ${skills || 'Not specified'}
- Experience: ${experience}
- Target role: ${targetRole}
- Industry: ${industry}
- City: ${city}
- Primary goal: ${goal}
- Plan tier: ${tier}

Return this EXACT JSON schema (no extra text, pure JSON only):
{
  "summary": "2-sentence personalised summary mentioning their background and path",
  "target_role": "${targetRole}",
  "estimated_transition_months": 12,
  "skill_gap_score": 55,
  "missing_critical_skills": ["skill1", "skill2", "skill3"],
  "phases": [
    {
      "phase_number": 1,
      "title": "Phase title",
      "duration": "0–3 months",
      "focus": "One-line focus",
      "is_locked": false,
      "skills": ["skill1", "skill2", "skill3", "skill4", "skill5"],
      "certifications": [
        {"name": "cert name", "provider": "NPTEL / IIT / Coursera / Udemy", "cost_inr": 0, "is_free": true, "duration_weeks": 8, "link": "https://nptel.ac.in"},
        {"name": "cert name 2", "provider": "Provider", "cost_inr": 2999, "is_free": false, "duration_weeks": 6, "link": "https://coursera.org"}
      ],
      "projects": [
        {"title": "Project title", "description": "2-sentence description relevant to India context", "difficulty": "Beginner", "tech_stack": ["tool1", "tool2"]},
        {"title": "Project 2", "description": "Description", "difficulty": "Intermediate", "tech_stack": ["tool1"]}
      ],
      "salary_range_inr": {
        "bangalore": {"min": 600000, "max": 1000000},
        "mumbai": {"min": 550000, "max": 950000},
        "delhi": {"min": 520000, "max": 900000},
        "pune": {"min": 500000, "max": 850000},
        "hyderabad": {"min": 530000, "max": 900000},
        "remote": {"min": 400000, "max": 700000}
      },
      "top_companies_india": ["Company1", "Company2", "Company3", "Company4"],
      "job_titles": ["Title1", "Title2", "Title3"]
    },
    {
      "phase_number": 2,
      "title": "Phase 2 title",
      "duration": "3–6 months",
      "focus": "Focus area",
      "is_locked": false,
      "skills": ["skill1", "skill2", "skill3", "skill4"],
      "certifications": [{"name": "cert", "provider": "provider", "cost_inr": 0, "is_free": true, "duration_weeks": 4, "link": "https://swayam.gov.in"}],
      "projects": [{"title": "proj", "description": "desc", "difficulty": "Intermediate", "tech_stack": ["tool"]}],
      "salary_range_inr": {"bangalore": {"min": 800000, "max": 1400000}, "mumbai": {"min": 750000, "max": 1300000}, "delhi": {"min": 700000, "max": 1200000}, "pune": {"min": 680000, "max": 1100000}, "hyderabad": {"min": 720000, "max": 1250000}, "remote": {"min": 600000, "max": 1000000}},
      "top_companies_india": ["Co1", "Co2", "Co3"],
      "job_titles": ["Title1", "Title2"]
    },
    {
      "phase_number": 3,
      "title": "Phase 3 title",
      "duration": "6–12 months",
      "focus": "Focus area",
      "is_locked": false,
      "skills": ["skill1", "skill2", "skill3"],
      "certifications": [{"name": "cert", "provider": "provider", "cost_inr": 1999, "is_free": false, "duration_weeks": 10, "link": "https://coursera.org"}],
      "projects": [{"title": "proj", "description": "desc", "difficulty": "Advanced", "tech_stack": ["tool"]}],
      "salary_range_inr": {"bangalore": {"min": 1000000, "max": 1800000}, "mumbai": {"min": 950000, "max": 1700000}, "delhi": {"min": 900000, "max": 1600000}, "pune": {"min": 850000, "max": 1500000}, "hyderabad": {"min": 900000, "max": 1650000}, "remote": {"min": 750000, "max": 1300000}},
      "top_companies_india": ["Co1", "Co2", "Co3"],
      "job_titles": ["Title1", "Title2"]
    },
    {
      "phase_number": 4,
      "title": "Phase 4 title",
      "duration": "12–24 months",
      "focus": "Focus area",
      "is_locked": false,
      "skills": ["skill1", "skill2"],
      "certifications": [{"name": "cert", "provider": "provider", "cost_inr": 4999, "is_free": false, "duration_weeks": 12, "link": "https://coursera.org"}],
      "projects": [{"title": "proj", "description": "desc", "difficulty": "Advanced", "tech_stack": ["tool"]}],
      "salary_range_inr": {"bangalore": {"min": 1500000, "max": 2800000}, "mumbai": {"min": 1400000, "max": 2600000}, "delhi": {"min": 1300000, "max": 2400000}, "pune": {"min": 1200000, "max": 2200000}, "hyderabad": {"min": 1300000, "max": 2500000}, "remote": {"min": 1000000, "max": 2000000}},
      "top_companies_india": ["Co1", "Co2", "Co3"],
      "job_titles": ["Title1", "Title2"]
    }
  ],
  "india_specific_tips": ["tip1", "tip2", "tip3"]
}

IMPORTANT RULES:
- Use real Indian company names (TCS, Infosys, Wipro, Zomato, Flipkart, CRED, Razorpay, Meesho, PhonePe, Ola, Dream11, Paytm, Juspay, etc.) relevant to the role
- Prioritise NPTEL, Swayam, IIT courses (mark cost_inr as 0, is_free as true)
- Projects should have India-context where possible (UPI apps, IPL datasets, Indian e-commerce etc.)
- Salary ranges must reflect real Indian 2024-25 market
- skill_gap_score: integer 0-100 representing how ready the person is for the target role`;
}

function parseRoadmapJSON(raw) {
  // Strip markdown fences if present
  let text = raw.replace(/```json\s*/gi, '').replace(/```\s*/gi, '').trim();
  // Find JSON boundaries
  const start = text.indexOf('{');
  const end   = text.lastIndexOf('}');
  if (start === -1 || end === -1) throw new Error('No JSON found in AI response');
  text = text.slice(start, end + 1);
  return JSON.parse(text);
}

// ═══════════════════════════════════════════════════════
//  ROADMAP DETAIL RENDERER
// ═══════════════════════════════════════════════════════
function openRoadmapDetail(idx) {
  STATE.currentRoadmap = idx;
  const rm = STATE.roadmaps[idx];
  if (!rm) return;

  const container = document.getElementById('detail-content');
  const maxSalary = 3000000;

  const formatLakh = v => v >= 100000 ? '₹' + (v/100000).toFixed(1) + 'L' : '₹' + v.toLocaleString('en-IN');
  const diffClass  = d => d === 'Beginner' ? 'diff-beginner' : d === 'Intermediate' ? 'diff-intermediate' : 'diff-advanced';

  let phasesHTML = '';
  (rm.phases || []).forEach((phase, i) => {
    const isLocked = phase.is_locked;

    // Skills
    const skillsHTML = (phase.skills || []).map(s => `<span class="skill-tag">${s}</span>`).join('');

    // Certs
    const certsHTML = (phase.certifications || []).map(c => `
      <div class="cert-item">
        <div><div class="cert-name">${c.name}</div><div class="cert-provider">${c.provider} · ${c.duration_weeks || '?'} weeks</div></div>
        <span class="cert-cost ${c.is_free ? 'free' : 'paid'}">${c.is_free ? 'FREE' : formatLakh(c.cost_inr)}</span>
      </div>`).join('');

    // Projects
    const projHTML = (phase.projects || []).map(p => `
      <div class="project-item">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
          <div class="project-title">${p.title}</div>
          <span class="diff-badge ${diffClass(p.difficulty)}">${p.difficulty}</span>
        </div>
        <div class="project-desc">${p.description}</div>
        <div class="project-tags">${(p.tech_stack||[]).map(t=>`<span class="project-tag">${t}</span>`).join('')}</div>
      </div>`).join('');

    // Salary bars
    const cities = ['bangalore','mumbai','delhi','pune','hyderabad','remote'];
    const salaryHTML = phase.salary_range_inr ? cities.map(city => {
      const s   = phase.salary_range_inr[city] || {};
      const pct = Math.min(100, ((s.max || 0) / maxSalary) * 100);
      return `<div class="salary-bar-item">
        <div class="salary-city">${city.charAt(0).toUpperCase()+city.slice(1)}</div>
        <div class="salary-bar-wrap"><div class="salary-bar-fill" style="width:0%" data-pct="${pct}"></div></div>
        <div class="salary-range">${formatLakh(s.min||0)} – ${formatLakh(s.max||0)}</div>
      </div>`;
    }).join('') : `<div style="text-align:center;padding:1rem;color:var(--text2);font-size:0.85rem">
      🔒 Salary data available on Starter plan ₹99/mo
      <br><button class="btn-upgrade" style="margin-top:10px" onclick="showView('paywall')">Unlock</button>
    </div>`;

    // Companies
    const companiesHTML = (phase.top_companies_india || []).map(c => `<span class="skill-tag" style="background:rgba(78,205,196,0.08);color:var(--teal2);border-color:rgba(78,205,196,0.2)">${c}</span>`).join('');

    phasesHTML += `
    <div class="phase-card ${isLocked ? 'locked' : ''}" id="phase-card-${i}">
      <div class="phase-card-header" onclick="togglePhase(${i})">
        <div class="phase-num ${isLocked ? 'locked-num' : ''}">${isLocked ? '🔒' : i+1}</div>
        <div class="phase-header-info">
          <div class="phase-title">${phase.title || 'Phase ' + (i+1)}</div>
          <div class="phase-duration">${phase.duration} · ${(phase.skills||[]).length} skills</div>
        </div>
        <div class="phase-chevron ${i===0 ? 'open' : ''}" id="chevron-${i}">▼</div>
      </div>
      ${isLocked ? `
        <div class="locked-overlay show">
          <div class="lock-icon">🔒</div>
          <div class="lock-msg">${phase.lock_reason || 'Upgrade to unlock this phase'}</div>
          <button class="btn-upgrade" onclick="showView('paywall')">Upgrade Plan</button>
        </div>` : `
        <div class="phase-card-body ${i===0 ? 'open' : ''}" id="body-${i}">
          <div class="phase-section">
            <div class="phase-section-title">Skills to learn</div>
            <div class="skills-chips">${skillsHTML}</div>
          </div>
          <div class="phase-section">
            <div class="phase-section-title">Certifications</div>
            <div class="cert-list">${certsHTML}</div>
          </div>
          <div class="phase-section">
            <div class="phase-section-title">Projects to build</div>
            <div class="project-list">${projHTML}</div>
          </div>
          <div class="phase-section">
            <div class="phase-section-title">Salary range (India)</div>
            <div class="salary-section">${salaryHTML}</div>
          </div>
          <div class="phase-section">
            <div class="phase-section-title">Top companies hiring</div>
            <div class="skills-chips">${companiesHTML}</div>
          </div>
          <div class="phase-section">
            <div class="phase-section-title">Job titles to target</div>
            <div class="skills-chips">${(phase.job_titles||[]).map(t=>`<span class="skill-tag" style="background:rgba(247,183,49,0.08);color:var(--amber);border-color:rgba(247,183,49,0.2)">${t}</span>`).join('')}</div>
          </div>
        </div>`}
    </div>`;
  });

  // Gap meter
  const gapScore = rm.skill_gap_score || 0;
  const gapColor = gapScore < 40 ? 'var(--red)' : gapScore < 70 ? 'var(--amber)' : 'var(--teal)';

  // Tips
  const tipsHTML = (rm.india_specific_tips || []).map(t =>
    `<div style="background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:10px 12px;font-size:0.84rem;color:var(--text2);margin-bottom:8px">💡 ${t}</div>`
  ).join('');

  container.innerHTML = `
    <div class="roadmap-detail-header">
      <div class="detail-role">Path to <span>${rm.target_role}</span></div>
      <div class="detail-meta">From: ${rm.current_role} · Generated ${rm.generated_at ? new Date(rm.generated_at).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : 'recently'}</div>
      <div class="detail-stats">
        <div class="detail-stat"><div class="detail-stat-val purple">${rm.estimated_transition_months || '?'} mo</div><div class="detail-stat-lbl">To transition</div></div>
        <div class="detail-stat"><div class="detail-stat-val teal">${(rm.phases||[]).filter(p=>!p.is_locked).length}/4</div><div class="detail-stat-lbl">Phases unlocked</div></div>
        <div class="detail-stat"><div class="detail-stat-val">${gapScore}%</div><div class="detail-stat-lbl">Skill match</div></div>
      </div>
      <div class="gap-meter-wrap">
        <div class="gap-meter-label"><span>Skill gap score</span><span style="color:${gapColor}">${gapScore}% ready</span></div>
        <div class="gap-meter-bar"><div class="gap-meter-fill" id="gap-fill" style="width:0%;background:${gapScore<40?'linear-gradient(90deg,var(--red),var(--amber))':gapScore<70?'linear-gradient(90deg,var(--amber),var(--teal))':'linear-gradient(90deg,var(--purple),var(--teal))'}"></div></div>
      </div>
      <div style="font-size:0.85rem;color:var(--text2);margin-top:8px">${rm.summary || ''}</div>
      ${(rm.missing_critical_skills||[]).length > 0 ? `
        <div style="margin-top:10px;font-size:0.8rem;color:var(--text2)">Critical skills to learn: ${rm.missing_critical_skills.map(s=>`<span class="skill-tag" style="font-size:0.75rem">${s}</span>`).join(' ')}</div>` : ''}
    </div>

    <div class="phases-list">${phasesHTML}</div>

    ${tipsHTML ? `
    <div style="margin-top:1.5rem">
      <div style="font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--text2);margin-bottom:10px">India-specific tips</div>
      ${tipsHTML}
    </div>` : ''}
  `;

  showView('detail');

  // Animate fills after render
  setTimeout(() => {
    const fill = document.getElementById('gap-fill');
    if (fill) fill.style.width = gapScore + '%';
    document.querySelectorAll('.salary-bar-fill[data-pct]').forEach(el => {
      el.style.width = el.dataset.pct + '%';
    });
  }, 100);
}

function togglePhase(i) {
  const body    = document.getElementById('body-' + i);
  const chevron = document.getElementById('chevron-' + i);
  if (!body) return;
  const isOpen = body.classList.toggle('open');
  if (chevron) chevron.classList.toggle('open', isOpen);
}

// ═══════════════════════════════════════════════════════
//  GENERATING ANIMATION
// ═══════════════════════════════════════════════════════
function animateGenSteps() {
  const steps = ['gstep-0','gstep-1','gstep-2','gstep-3'];
  steps.forEach(id => document.getElementById(id).className = 'gen-step');
  document.getElementById('gstep-0').classList.add('current');
  let i = 0;
  const iv = setInterval(() => {
    document.getElementById(steps[i]).classList.remove('current');
    document.getElementById(steps[i]).classList.add('done');
    i++;
    if (i < steps.length) {
      document.getElementById(steps[i]).classList.add('current');
    } else {
      clearInterval(iv);
    }
  }, 1800);
}

// ═══════════════════════════════════════════════════════
//  BILLING TOGGLE
// ═══════════════════════════════════════════════════════
function toggleBilling() {
  STATE.annualBilling = !STATE.annualBilling;
  const toggle = document.getElementById('billing-toggle');
  toggle.classList.toggle('on', STATE.annualBilling);

  const prices = STATE.annualBilling
    ? { starter: ['₹799', '/year', '₹389 saved vs monthly'],
        pro:     ['₹2,499', '/year', '₹1,089 saved vs monthly'],
        elite:   ['₹4,999', '/year', '₹2,189 saved vs monthly'] }
    : { starter: ['₹99',  '/month', '₹799/year — save ₹389'],
        pro:     ['₹299', '/month', '₹2,499/year — save ₹1,089'],
        elite:   ['₹599', '/month', '₹4,999/year — save ₹2,189'] };

  ['starter','pro','elite'].forEach(plan => {
    const [price, period, save] = prices[plan];
    document.getElementById(plan + '-price').innerHTML = price + ` <span>${period}</span>`;
    document.getElementById(plan + '-save').textContent = save;
  });
}

// ═══════════════════════════════════════════════════════
//  TOAST
// ═══════════════════════════════════════════════════════
let toastTimer;
function showToast(msg, type = 'success') {
  const toast   = document.getElementById('toast');
  const iconEl  = document.getElementById('toast-icon');
  const msgEl   = document.getElementById('toast-msg');
  const icons   = { success: '✓', error: '✕', info: 'ℹ' };
  iconEl.textContent = icons[type] || '✓';
  msgEl.textContent  = msg;
  toast.className    = 'toast ' + type + ' show';
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => toast.classList.remove('show'), 3500);
}

// ═══════════════════════════════════════════════════════
//  USER MENU
// ═══════════════════════════════════════════════════════
function toggleUserMenu() {
  document.getElementById('user-menu').classList.toggle('open');
}
document.addEventListener('click', e => {
  const btn  = document.getElementById('user-avatar-btn');
  const menu = document.getElementById('user-menu');
  if (btn && !btn.contains(e.target)) menu.classList.remove('open');
});

// ═══════════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════════
window.addEventListener('load', () => {
  initGoogleSignIn();

  if (loadState() && STATE.user) {
    if (STATE.profile) {
      enterApp();
    } else {
      showScreen('onboarding');
    }
  } else {
    showScreen('login');
  }
});
</script>
</body>
</html>
